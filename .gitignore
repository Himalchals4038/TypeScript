# Dependency directories
# These are installed by package managers and can be re-installed.
node_modules/

# Build output
# This is the compiled JavaScript code from your TypeScript source.
dist/
build/
out/

# TypeScript build info
# This file is used by TypeScript for incremental compilation.
*.tsbuildinfo

# Log files
# Various tools generate log files that shouldn't be in version control.
*.log
npm-debug.log*
yarn-debug.log*

# IDE and editor directories
# These are specific to your local development environment.
.vscode/
.idea/

# OS-generated files
# Files generated by the operating system that are not part of the project.
.DS_Store
Thumbs.db